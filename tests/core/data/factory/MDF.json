          "type": "null"
        },
        "linear_solver_settings": {
          "type": "object",
          "properties": {
            "store_residuals": {
              "type": "boolean"
            },
            "use_ilu_precond": {
              "type": "boolean"
            },
            "save_when_fail": {
              "type": "boolean"
            }
          },
          "required": [
            "save_when_fail",
            "store_residuals",
            "use_ilu_precond"
          ]
        },
        "log_convergence": {
          "type": "boolean"
        },
        "max_mda_iter": {
          "type": "integer"
        },
        "max_consecutive_unsuccessful_iterations": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "tolerance": {
          "type": "number"
        },
        "use_lu_fact": {
          "type": "boolean"
        },
        "warm_start": {
          "type": "boolean"
        },
        "acceleration_method": {
          "type": "string"
        },
        "over_relaxation_factor": {
          "type": "number"
        },
        "execute_before_linearizing": {
          "type": "boolean"
        },
        "n_processes": {
          "type": "integer"
        },
        "use_threading": {
          "type": "boolean"
        },
        "chain_linearize": {
          "type": "boolean"
        },
        "inner_mda_settings": {
          "type": "object",
          "properties": {
