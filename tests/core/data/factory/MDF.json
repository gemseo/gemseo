              "properties": {
                "store_residuals": {
                  "type": "boolean"
                },
                "use_ilu_precond": {
                  "type": "boolean"
                },
                "save_when_fail": {
                  "type": "boolean"
                }
              },
              "required": [
                "save_when_fail",
                "store_residuals",
                "use_ilu_precond"
              ]
            },
            "log_convergence": {
              "type": "boolean"
            },
            "max_mda_iter": {
              "type": "integer"
            },
            "max_consecutive_unsuccessful_iterations": {
              "type": "integer"
            },
            "name": {
              "type": "string"
            },
            "tolerance": {
              "type": "number"
            },
            "use_lu_fact": {
              "type": "boolean"
            },
            "warm_start": {
              "type": "boolean"
            }
          },
          "required": [
            "coupling_structure",
            "linear_solver_settings",
            "log_convergence",
            "max_consecutive_unsuccessful_iterations",
            "max_mda_iter",
            "name",
